BROWSERLESS_URL=wss://browserless.chatle.nl
BROWSERLESS_TOKEN=replace-me
DATA_DIR=./data
PORT=3011
WEB_ORIGIN=http://localhost:5173
AGENT_BROWSER_BIN=agent-browser
SESSION_IDLE_TTL_MS=300000

# --- Stealth (Cloudflare / WAF evasion at the browser-fingerprint layer) ---
# Defaults are sensible; override any of these to tune.
STEALTH_ENABLED=true
# Stripped of "HeadlessChrome", matches a real Win10 + Chrome 148 UA.
STEALTH_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/148.0.0.0 Safari/537.36
# Whitespace-separated Chromium launch args. Each token is a single flag —
# values that themselves contain commas (e.g. --disable-features=A,B) stay intact.
# These are folded into the wss `launch` query so browserless launches Chrome accordingly.
STEALTH_LAUNCH_ARGS=--disable-blink-features=AutomationControlled --disable-features=IsolateOrigins,site-per-process --no-default-browser-check --no-first-run
# Default args to strip from the Chromium launch — removes the "Chrome is being
# controlled by automated test software" banner and the navigator.webdriver flag.
STEALTH_IGNORE_DEFAULT_ARGS=--enable-automation
# Init script run before every navigation. Empty to disable. The default points
# at apps/server/stealth/init.js (navigator.webdriver, plugins, WebGL, etc.).
# STEALTH_INIT_SCRIPT=
